PORT=8787
HOST=127.0.0.1

# OpenRouter backend authority
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_API_KEY_QWEN3_CODER=your_qwen3_coder_openrouter_api_key
OPENROUTER_API_KEY_GPT_OSS_120B_PLANNER=your_gpt_oss_120b_planner_openrouter_api_key
OPENROUTER_API_KEY_NEMOTRON_3_SUPER_120B=your_nemotron_3_super_120b_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=default
OPENROUTER_MODELS=your_hidden_provider_target_1,your_hidden_provider_target_2

APP_NAME=mosaicstack-local
DEFAULT_SYSTEM_PROMPT=You are a concise, reliable assistant operating through a local OpenRouter proxy.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# Backend-owned workflow model routing
CHAT_MODEL=google/gemma-4-31b-it:free
CODE_AGENT_MODEL=qwen/qwen3-coder:free
STRUCTURED_PLAN_MODEL=openai/gpt-oss-120b:free
MATRIX_ANALYZE_MODEL=nvidia/nemotron-3-super-120b-a12b:free
FAST_FALLBACK_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
DIALOG_FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct:free

MODEL_ROUTING_MODE=policy
ALLOW_MODEL_FALLBACK=true
MODEL_ROUTING_FAIL_CLOSED=true
MODEL_ROUTING_LOG_ENABLED=false
MODEL_ROUTING_LOG_PATH=.local-ai/logs/WORKFLOW_MODEL_ROUTING.log.md

# Legacy router compatibility inputs (do not remove).
# Chat request routing authority is centralized in:
# server/src/lib/routing-authority.ts
LLM_ROUTER_ENABLED=false
LLM_ROUTER_MODE=rules_first
LLM_REQUIRE_FREE_MODELS=true
LLM_MAX_FALLBACKS=2
LLM_ROUTER_FAIL_CLOSED=true
LLM_ROUTER_LOG_ENABLED=false
LLM_ROUTER_LOG_PATH=.local-ai/logs/ROUTER_DECISIONS.log.md
LLM_MODEL_RUN_LOG_PATH=.local-ai/logs/MODEL_RUNS.log.md
LLM_PROMPT_EVIDENCE_LOG_PATH=.local-ai/logs/PROMPT_EVIDENCE.log.md
LLM_ROUTER_POLICY_PATH=config/llm-router.yml
LLM_PROMPT_CLASSIFIER_PATH=
LLM_MODEL_MAP_PATH=
LLM_FALLBACK_POLICY_PATH=

LLM_DEFAULT_MODEL=default
LLM_FALLBACK_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
LLM_MODEL_CODING=qwen/qwen3-coder:free
LLM_MODEL_REPO_REVIEW=openai/gpt-oss-120b:free
LLM_MODEL_ARCHITECTURE=nvidia/nemotron-3-super-120b-a12b:free
LLM_MODEL_DEEP_REASONING=openai/gpt-oss-120b:free
LLM_MODEL_LONG_CONTEXT=google/gemma-4-31b-it:free
LLM_MODEL_UI_REVIEW=meta-llama/llama-3.3-70b-instruct:free
LLM_MODEL_DAILY=qwen/qwen3-next-80b-a3b-instruct:free

# GitHub backend authority
GITHUB_TOKEN=your_github_token
GITHUB_ALLOWED_REPOS=your-org/your-repo
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_DEFAULT_OWNER=your-org
GITHUB_BRANCH_PREFIX=mosaicstack/github
GITHUB_REQUEST_TIMEOUT_MS=8000
GITHUB_PLAN_TTL_MS=720000
# Production warning:
# - "memory" is process-local and ephemeral under serverless/cold-start execution.
# - "file" is still local filesystem state and must not be treated as durable on Vercel.
# - For durable production persistence, use an external persistent store in a future slice.
GITHUB_ACTION_STORE_MODE=memory
GITHUB_ACTION_STORE_FILE_PATH=.local-ai/state/github-action-store.json
GITHUB_MAX_CONTEXT_FILES=6
GITHUB_MAX_CONTEXT_BYTES=32768
GITHUB_SMOKE_REPO=your-org/your-repo
GITHUB_SMOKE_BASE_BRANCH=main
GITHUB_SMOKE_TARGET_BRANCH=mosaicstack/github-smoke
GITHUB_SMOKE_ENABLED=false

GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=

# GitHub user OAuth login. Required for /api/auth/github/start to begin a real
# GitHub OAuth flow instead of using the local stub fallback.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_AUTHORIZE_URL=https://github.com/login/oauth/authorize
GITHUB_OAUTH_TOKEN_URL=https://github.com/login/oauth/access_token
GITHUB_OAUTH_SCOPES=repo,read:user

MOSAIC_STACK_ADMIN_PASSWORD=your_admin_password_placeholder
MOSAIC_STACK_SESSION_SECRET=your_long_session_secret_placeholder
MOSAIC_STACK_SESSION_TTL_SECONDS=86400
INTEGRATION_AUTH_STORE_MODE=file
INTEGRATION_AUTH_STORE_FILE_PATH=.local-ai/state/integration-auth-store.json
INTEGRATION_AUTH_ENCRYPTION_CURRENT_KEY_ID=integration-auth-v1
INTEGRATION_AUTH_ENCRYPTION_CURRENT_KEY_VERSION=1
INTEGRATION_AUTH_ENCRYPTION_CURRENT_KEY=
# Comma-separated entries: keyId@keyVersion:keyMaterial
INTEGRATION_AUTH_ENCRYPTION_PREVIOUS_KEYS=
# Opt-in live smoke only: GitHub integration auth rotation gate
INTEGRATION_AUTH_ROTATION_LIVE_ENABLED=false
INTEGRATION_AUTH_ROTATION_LIVE_GITHUB_CODE_VN=
INTEGRATION_AUTH_ROTATION_LIVE_GITHUB_CODE_VN1=
INTEGRATION_AUTH_ROTATION_LIVE_KEY_VN_ID=
INTEGRATION_AUTH_ROTATION_LIVE_KEY_VN_VERSION=1
INTEGRATION_AUTH_ROTATION_LIVE_KEY_VN_MATERIAL=
INTEGRATION_AUTH_ROTATION_LIVE_KEY_VN1_ID=
INTEGRATION_AUTH_ROTATION_LIVE_KEY_VN1_VERSION=2
INTEGRATION_AUTH_ROTATION_LIVE_KEY_VN1_MATERIAL=
INTEGRATION_AUTH_ROTATION_LIVE_EXPECTED_GITHUB_LOGIN=
INTEGRATION_AUTH_ROTATION_LIVE_MATRIX_ENABLED=false
INTEGRATION_AUTH_ROTATION_LIVE_MATRIX_LOGIN_TOKEN_VN=
INTEGRATION_AUTH_ROTATION_LIVE_MATRIX_LOGIN_TOKEN_VN1=
INTEGRATION_AUTH_ROTATION_LIVE_MATRIX_EXPECTED_USER_ID=

# Matrix backend authority
MATRIX_ENABLED=false
MATRIX_REQUIRED=false
MATRIX_BASE_URL=https://matrix.example
MATRIX_HOMESERVER_URL=
MATRIX_ACCESS_TOKEN=your_matrix_access_token
MATRIX_REFRESH_TOKEN=your_matrix_refresh_token
MATRIX_CLIENT_ID=your_matrix_client_id
MATRIX_TOKEN_EXPIRES_AT=YYYY-MM-DDTHH:MM:SSZ
MATRIX_EXPECTED_USER_ID=@user:matrix.example
MATRIX_REQUEST_TIMEOUT_MS=5000

# Optional Matrix evidence smoke. Use an existing room's Element "Advanced" ->
# "Internal room ID" value, e.g. !abc123:matrix.org. The Matrix backend user
# must already be joined and allowed to send messages there.
MATRIX_EVIDENCE_ROOM_ID=
MATRIX_EVIDENCE_APPROVALS_ROOM_ID=
MATRIX_EVIDENCE_PROVENANCE_ROOM_ID=
MATRIX_EVIDENCE_VERIFICATION_ROOM_ID=
MATRIX_EVIDENCE_TOPIC_CHANGE_ROOM_ID=
MATRIX_EVIDENCE_WRITES_ENABLED=false
MATRIX_EVIDENCE_WRITES_REQUIRED=false
MATRIX_SSO_REDIRECT_PATH=/_matrix/client/v3/login/sso/redirect
MATRIX_LOGIN_TOKEN_TYPE=m.login.token

# Matrix workflow policy (parsed-only / deferred; not runtime-authoritative)
MATRIX_ANALYZE_LLM_ENABLED=false
MATRIX_EXECUTE_APPROVAL_REQUIRED=true
MATRIX_VERIFY_AFTER_EXECUTE=true
MATRIX_ALLOWED_ACTION_TYPES=set_room_topic
MATRIX_FAIL_CLOSED=true

MATRIX_SMOKE_ROOM_ID=your-dedicated-room-id
MATRIX_SMOKE_TOPIC_PREFIX=MosaicStack smoke
