PORT=8787
HOST=127.0.0.1
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Provider execution target for the public default alias.
OPENROUTER_MODEL=openrouter/auto
# Hidden provider fallback pool; not exposed directly through GET /models.
OPENROUTER_MODELS=openrouter/auto
APP_NAME=local-openrouter-chat
DEFAULT_SYSTEM_PROMPT=You are a concise, reliable assistant operating through a local OpenRouter proxy.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
# Rules-first LLM router policy (disabled by default; backend-owned only)
LLM_ROUTER_ENABLED=false
LLM_ROUTER_MODE=rules_first
LLM_REQUIRE_FREE_MODELS=true
LLM_MAX_FALLBACKS=2
LLM_ROUTER_FAIL_CLOSED=true
LLM_ROUTER_LOG_ENABLED=false
# Private append-only local evidence logs under .local-ai/; warnings only if logging fails.
LLM_ROUTER_LOG_PATH=.local-ai/logs/ROUTER_DECISIONS.log.md
LLM_MODEL_RUN_LOG_PATH=.local-ai/logs/MODEL_RUNS.log.md
LLM_PROMPT_EVIDENCE_LOG_PATH=.local-ai/logs/PROMPT_EVIDENCE.log.md
LLM_ROUTER_POLICY_PATH=config/llm-router.yml
LLM_PROMPT_CLASSIFIER_PATH=
LLM_MODEL_MAP_PATH=
LLM_FALLBACK_POLICY_PATH=
LLM_DEFAULT_MODEL=openrouter/free
LLM_FALLBACK_MODEL=openai/gpt-oss-120b:free
LLM_MODEL_CODING=qwen/qwen3-coder:free
LLM_MODEL_REPO_REVIEW=mistralai/devstral-2512:free
LLM_MODEL_ARCHITECTURE=qwen/qwen3-next-80b-a3b-instruct:free
LLM_MODEL_DEEP_REASONING=deepseek/deepseek-r1-0528:free
LLM_MODEL_LONG_CONTEXT=nvidia/nemotron-3-super-120b-a12b:free
LLM_MODEL_UI_REVIEW=google/gemma-4-26b-a4b-it:free
LLM_MODEL_DAILY=openai/gpt-oss-120b:free
# Matrix read-only backend (disabled by default; server-owned access only)
MATRIX_ENABLED=false
MATRIX_REQUIRED=false
MATRIX_BASE_URL=https://matrix.example
MATRIX_ACCESS_TOKEN=
MATRIX_EXPECTED_USER_ID=
MATRIX_REQUEST_TIMEOUT_MS=5000
# Optional live Matrix smoke for the backend-owned topic-update flow.
# The smoke script reads the repo-root .env file, so copy this example to .env.
MATRIX_SMOKE_ROOM_ID=
MATRIX_SMOKE_TOPIC_PREFIX=ModelGate smoke
