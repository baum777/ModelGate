{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "web/dist",
  "functions": {
    "api/[...path].ts": {
      "maxDuration": 60,
      "includeFiles": "config/**/*.yml"
    },
    "api/matrix/[...path].ts": {
      "maxDuration": 60,
      "includeFiles": "config/**/*.yml"
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/models",
      "destination": "/api/models"
    },
    {
      "source": "/chat",
      "destination": "/api/chat"
    },
    {
      "source": "/api/matrix/(.*)",
      "destination": "/api/matrix/[...path]?...path=$1"
    },
    {
      "source": "/api/auth/(.*)",
      "destination": "/api/[...path]?...path=$1"
    },
    {
      "source": "/api/github/(.*)",
      "destination": "/api/[...path]?...path=$1"
    }
  ]
}
