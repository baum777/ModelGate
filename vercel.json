{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "web/dist",
  "functions": {
    "api/[...path].ts": {
      "runtime": "nodejs20.x",
      "maxDuration": 10,
      "includeFiles": [
        "config/llm-router.yml"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/models",
      "destination": "/api/models"
    },
    {
      "source": "/chat",
      "destination": "/api/chat"
    }
  ]
}
